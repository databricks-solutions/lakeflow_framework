{
  "datasets": [
    {
      "name": "ds_dq_kpis",
      "displayName": "Fact resolution KPIs",
      "queryLines": [
        "SELECT COUNT(*) AS total_order_lines, SUM(CASE WHEN part_sk=-1 THEN 1 ELSE 0 END) AS unknown_part_lines, SUM(CASE WHEN supplier_sk=-1 THEN 1 ELSE 0 END) AS unknown_supplier_lines, SUM(CASE WHEN customer_sk=-1 THEN 1 ELSE 0 END) AS unknown_customer_lines FROM fct_order_lines"
      ]
    },
    {
      "name": "ds_versioned_counts",
      "displayName": "Dimensions with SCD2 history",
      "queryLines": [
        "SELECT (SELECT COUNT(*) FROM (SELECT supplier_key FROM dim_supplier WHERE supplier_key<>-1 GROUP BY supplier_key HAVING COUNT(*)>1)) AS suppliers_with_history, (SELECT COUNT(*) FROM (SELECT part_key FROM dim_part WHERE part_key<>-1 GROUP BY part_key HAVING COUNT(*)>1)) AS parts_with_history"
      ]
    },
    {
      "name": "ds_dim_rows",
      "displayName": "Dimension rows vs current entities",
      "queryLines": [
        "SELECT 'Supplier' AS dimension, COUNT(*) AS total_rows, COUNT(DISTINCT supplier_key) AS current_entities FROM dim_supplier WHERE supplier_key<>-1 UNION ALL SELECT 'Part', COUNT(*), COUNT(DISTINCT part_key) FROM dim_part WHERE part_key<>-1 UNION ALL SELECT 'Customer', COUNT(*), COUNT(DISTINCT customer_key) FROM dim_customer WHERE customer_key<>-1"
      ]
    },
    {
      "name": "ds_supplier_history",
      "displayName": "Supplier version history (SCD2)",
      "queryLines": [
        "SELECT supplier_key, supplier_name, region_name, __START_AT, __END_AT FROM dim_supplier WHERE supplier_key IN (SELECT supplier_key FROM dim_supplier WHERE supplier_key<>-1 GROUP BY supplier_key HAVING COUNT(*)>1) ORDER BY supplier_key, __START_AT"
      ]
    },
    {
      "name": "ds_returns_by_region",
      "displayName": "Return rate by region",
      "queryLines": [
        "SELECT c.region_name AS region_name, SUM(CASE WHEN f.return_flag='R' THEN f.quantity ELSE 0 END)/NULLIF(SUM(f.quantity),0) AS return_rate FROM fct_order_lines f JOIN dim_customer c ON f.customer_sk=c.customer_sk WHERE c.region_name<>'Unknown' AND c.region_name IS NOT NULL GROUP BY 1"
      ]
    }
  ],
