{
  "datasets": [
    {
      "name": "ds_kpis",
      "displayName": "Headline KPIs",
      "queryLines": [
        "SELECT SUM(net_sales) AS net_sales, COUNT(DISTINCT order_key) AS orders, SUM(quantity) AS units_sold, SUM(net_sales)/NULLIF(COUNT(DISTINCT order_key),0) AS avg_order_value, AVG(CASE WHEN receipt_date <= commit_date THEN 1.0 ELSE 0.0 END) AS on_time_rate, SUM(CASE WHEN return_flag='R' THEN quantity ELSE 0 END)/NULLIF(SUM(quantity),0) AS return_rate FROM fct_order_lines"
      ]
    },
    {
      "name": "ds_sales_by_month",
      "displayName": "Net sales by month",
      "queryLines": [
        "SELECT DATE_TRUNC('MONTH', order_date) AS order_month, SUM(net_sales) AS net_sales FROM fct_order_lines WHERE order_date IS NOT NULL GROUP BY 1 ORDER BY 1"
      ]
    },
    {
      "name": "ds_sales_by_region",
      "displayName": "Net sales by region",
      "queryLines": [
        "SELECT c.region_name AS region_name, SUM(f.net_sales) AS net_sales FROM fct_order_lines f JOIN dim_customer c ON f.customer_sk=c.customer_sk WHERE c.region_name IS NOT NULL AND c.region_name<>'Unknown' GROUP BY 1"
      ]
    },
    {
      "name": "ds_sales_by_segment",
      "displayName": "Net sales by market segment",
      "queryLines": [
        "SELECT c.market_segment AS market_segment, SUM(f.net_sales) AS net_sales FROM fct_order_lines f JOIN dim_customer c ON f.customer_sk=c.customer_sk WHERE c.market_segment IS NOT NULL AND c.market_segment<>'Unknown' GROUP BY 1"
      ]
    },
    {
      "name": "ds_ontime_by_shipmode",
      "displayName": "On-time delivery rate by ship mode",
      "queryLines": [
        "SELECT ship_mode, AVG(CASE WHEN receipt_date<=commit_date THEN 1.0 ELSE 0.0 END) AS on_time_rate FROM fct_order_lines WHERE ship_mode IS NOT NULL GROUP BY 1"
      ]
    },
    {
      "name": "ds_top_suppliers",
      "displayName": "Top suppliers by net sales",
      "queryLines": [
        "SELECT s.supplier_name AS supplier_name, SUM(f.net_sales) AS net_sales FROM fct_order_lines f JOIN dim_supplier s ON f.supplier_sk=s.supplier_sk WHERE s.supplier_name<>'Unknown' GROUP BY 1 ORDER BY 2 DESC LIMIT 10"
      ]
    }
  ],
